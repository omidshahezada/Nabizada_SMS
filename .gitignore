# Ignore dependencies
/vendor
/node_modules

# Ignore environment files
.env
.env.*
!.env.example

# Ignore application key cache
/bootstrap/cache/*.php
!/bootstrap/cache/.gitignore

# Ignore storage files
/storage/*.key
/storage/app/public
/storage/framework/cache/*
/storage/framework/sessions/*
/storage/framework/testing/*
/storage/framework/views/*
/storage/logs/*

# Keep directory structure
!/storage/framework/cache/.gitignore
!/storage/framework/sessions/.gitignore
!/storage/framework/testing/.gitignore
!/storage/framework/views/.gitignore
!/storage/logs/.gitignore

# Ignore compiled frontend assets
/public/build
/public/hot
/public/storage

# Ignore IDE/editor files
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# Ignore OS files
.DS_Store
Thumbs.db
desktop.ini

# Ignore Composer lock (optional)
# composer.lock

# Ignore npm lock (optional)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# Ignore PHPUnit cache
.phpunit.result.cache

# Ignore Laravel Pint cache
.pint.cache

# Ignore Rector cache
.rector/

# Ignore Pest cache
.pest.cache

# Ignore npm logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Ignore test coverage
coverage/
.phpunit.cache/

# Ignore temporary files
*.log
*.tmp
*.temp

# Ignore generated IDE helper files
.phpstorm.meta.php
_ide_helper.php
_ide_helper_models.php
node_modules
